<UserControl x:Class="KFA.MyBlogWPF.Components.LoginDetailForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KFA.MyBlogWPF.Components"
             xmlns:converters="clr-namespace:KFA.MyBlogWPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20 20 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" SharedSizeGroup="Label" />
                <ColumnDefinition Width="*" MaxWidth="250" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       FontWeight="Bold"
                       Text="Login" />
            <TextBox Grid.Column="1"
                     Margin="20 0 0 0"
                     x:Name="LoginTextBox"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
        <Grid Grid.Row="1" Margin="20 20 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" SharedSizeGroup="Label" />
                <ColumnDefinition Width="*" MaxWidth="250" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="1" 
                       Grid.Column="0"
                       FontWeight="Bold"
                       Text="Password" />
            <TextBox Grid.Row="1"
                       Grid.Column="1"
                       Margin="20 0 0 0"
                       Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
        <Grid Grid.Row="2" Margin="20 20 0 0" Visibility="{Binding HasErrors, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock FontWeight="Bold"                              
                   Foreground="Red"
                   Text="{Binding ErrorString}" />
        </Grid>
        <WrapPanel Grid.Row="3" Margin="0 30 0 0">
            <Button Content="Login" 
                    Command="{Binding LoginCommand}" 
                    CommandParameter="{Binding ElementName=LoginTextBox, Path=Text}"
                    Margin="0 0 10 0"
                    IsEnabled="{Binding CanSubmit}"/>
            <TextBlock Margin="10 0" Text="Not a member? Register now" />
            <Button Content="Register" 
                    Command="{Binding GoToRegisterCommand}" 
                    Style="{StaticResource ButtonSecondary}" />
        </WrapPanel>
    </Grid>
</UserControl>
