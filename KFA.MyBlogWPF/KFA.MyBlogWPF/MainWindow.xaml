<Window x:Class="KFA.MyBlogWPF.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:custom="clr-namespace:ModalControl;assembly=ModalControl"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KFA.MyBlogWPF" 
        xmlns:views="clr-namespace:KFA.MyBlogWPF.Views"
        xmlns:tag_vms="clr-namespace:KFA.MyBlogWPF.ViewModels.Tags"
        xmlns:articles_views="clr-namespace:KFA.MyBlogWPF.Views.Article"
        xmlns:articles_vms="clr-namespace:KFA.MyBlogWPF.ViewModels.Articles"
        xmlns:comments_views="clr-namespace:KFA.MyBlogWPF.Views.Comments"
        xmlns:comments_vms="clr-namespace:KFA.MyBlogWPF.ViewModels.Comments"
        xmlns:tag_views="clr-namespace:KFA.MyBlogWPF.Views"
        xmlns:user_vms="clr-namespace:KFA.MyBlogWPF.ViewModels.Users"
        xmlns:user_views="clr-namespace:KFA.MyBlogWPF.Views.Users"
        xmlns:vms="clr-namespace:KFA.MyBlogWPF.ViewModels"
        xmlns:role_vms="clr-namespace:KFA.MyBlogWPF.ViewModels.Roles"
        xmlns:role_views="clr-namespace:KFA.MyBlogWPF.Views.Roles"
        xmlns:converters="clr-namespace:KFA.MyBlogWPF.Converters"
        mc:Ignorable="d"
        FontSize="14"
        Title="MyBlog" Height="600" Width="800">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <DataTemplate DataType="{x:Type articles_vms:AddArticleViewModel}">
            <articles_views:AddArticleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type articles_vms:EditArticleViewModel}">
            <articles_views:EditArticleView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type comments_vms:AddCommentViewModel}">
            <comments_views:AddCommentView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type comments_vms:EditCommentViewModel}">
            <articles_views:EditArticleView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:AddTagViewModel}">
            <views:AddTagView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:EditTagViewModel}">
            <views:EditTagView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type user_vms:EditUserViewModel}">
            <user_views:EditUserView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type role_vms:AddRoleViewModel}">
            <role_views:AddRoleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type role_vms:EditRoleViewModel}">
            <role_views:EditRoleView />
        </DataTemplate>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
        <Grid>
            <custom:Modal Panel.ZIndex="1" IsOpen="{Binding IsModalOpen}">
                <ContentControl Margin="50 25" Content="{Binding CurrentModalViewModal}" />
            </custom:Modal>
            <TabControl x:Name="Menu">
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource TabHeader}" Margin="5" Text="Articles" />
                    </TabItem.Header>
                    <TabItem.Content>
                        <Grid>
                            <articles_views:ArticlesView DataContext="{Binding ArticlesViewModel}"/>
                        </Grid>
                    </TabItem.Content>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource TabHeader}" Margin="5" Text="Tags" />
                        </StackPanel>
                    </TabItem.Header>
                    <TabItem.Content>
                            <Grid>
                                <views:TagsView DataContext="{Binding TagsViewModel}"/>
                            </Grid>
                    </TabItem.Content>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource TabHeader}" Margin="5" Text="User" />
                    </TabItem.Header>
                    <TabItem.Content>
                        <Grid>
                            <user_views:UsersView DataContext="{Binding UsersViewModel}"/>
                        </Grid>
                    </TabItem.Content>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource TabHeader}" Margin="5" Text="Role" />
                    </TabItem.Header>
                    <TabItem.Content>
                        <Grid>
                            <views:RolesView DataContext="{Binding RolesViewModel}"/>
                        </Grid>
                    </TabItem.Content>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource TabHeader}" Margin="5" Text="Login" />
                    </TabItem.Header>
                    <TabItem.Content>
                        <Grid>
                            <views:LoginView DataContext="{Binding LoginViewModel}"
                                             Visibility="{Binding DataContext.IsLogin, 
                                                ElementName=MainWindowRoot,
                                                Converter={StaticResource  BoolToVisibilityConverter}}"/>
                            <views:RegisterView DataContext="{Binding RegisterViewModel}" 
                                                Visibility="{Binding DataContext.IsRegister, 
                                                    ElementName=MainWindowRoot,
                                                Converter={StaticResource  BoolToVisibilityConverter}}"/>
                            <views:LogoutView DataContext="{Binding LogoutViewModel}"
                                              Visibility="{Binding DataContext.IsSignedIn, 
                                                    ElementName=MainWindowRoot,
                                                Converter={StaticResource  BoolToVisibilityConverter}}"/>
                        </Grid>
                    </TabItem.Content>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</Window>
