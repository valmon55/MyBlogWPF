<UserControl x:Class="KFA.MyBlogWPF.Views.Article.AddArticleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KFA.MyBlogWPF.Views.Article"
             xmlns:components="clr-namespace:KFA.MyBlogWPF.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                   Text="Add Article" 
                   Padding="10 0 0 0" 
                   Style="{StaticResource PageHeader}" />

            <components:ArticleDetailForm 
            Grid.Row="1" 
            Margin="0 30 0 0"
            DataContext= "{Binding ArticleDetailsFormViewModel}" />
        </Grid>
    </Grid>
</UserControl>
